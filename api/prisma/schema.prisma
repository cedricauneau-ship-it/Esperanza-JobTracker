generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String
  passwordHash String
  createdAt    DateTime @default(now())

  jobOffers    JobOffer[]
  applications Application[]
  filters      UserFilters?
}

model JobOffer {
  id          String   @id @default(uuid())
  externalId  String   @unique
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  title       String
  company     String
  url         String
  description String
  location    String
  remote      String
  salary      String?
  source      String
  publishedAt DateTime
  scrapedAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now()) // dernière fois que l'offre est apparue dans le scraping
  status      String   @default("to_review")

  application Application?
}

model UserFilters {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])

  excludedStacks    String[]
  excludedKeywords  String[]
  excludedCompanies String[]
  requiredStacks    String[]
  contractTypes     String[]
  remoteOnly        Boolean  @default(false)

  departement       String?
  commune           String?
  radius            Int?

  followUpDays      Int      @default(7)
  expiredAfterDays  Int      @default(14) // nombre de jours avant de marquer une offre comme expirée

  updatedAt         DateTime @updatedAt
}

model Application {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  jobOfferId   String   @unique
  jobOffer     JobOffer @relation(fields: [jobOfferId], references: [id])

  appliedAt    DateTime @default(now())
  followUpAt   DateTime
  followUpSent Boolean  @default(false)
  notes        String?

  interviews   Interview[]
}

model Interview {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])

  scheduledAt   DateTime
  type          String
  notes         String?
}

model ScraperConfig {
  id            String    @id @default(uuid())
  source        String    @unique // "indeed", "francetravail"
  currentPage   Int       @default(1)
  lastScrapedAt DateTime?
}